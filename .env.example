# Required
SPAMFIGHTER_BOT_TOKEN=replace-with-your-discord-bot-token

# Optional AI rule review support
SPAMFIGHTER_OPENAI_API_KEY=
SPAMFIGHTER_OPENAI_MODEL=gpt-5.4-mini

# Optional paths. Defaults work for local runs from this repository root.
SPAMFIGHTER_CONFIG_PATH=config.toml
SPAMFIGHTER_SPAM_RULES_PATH=spam_rules.toml
SPAMFIGHTER_STATE_DB_PATH=spamfighter_state.sqlite3
SPAMFIGHTER_DOMAIN_BLOCKLISTS_DIR=domain_blocklists

# Optional Postgres backend for managed spam rules
SPAMFIGHTER_SPAM_RULES_DATABASE_URL=
